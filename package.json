{
  "name": "gfall",
  "version": "0.2.0",
  "description": "Fetch multiple Git repositories concurrently",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jermic/gfall.git"
  },
  "homepage": "https://github.com/Jermic/gfall#readme",
  "bugs": {
    "url": "https://github.com/Jermic/gfall/issues"
  },
  "files": [
    "dist/gfall.js"
  ],
  "bin": {
    "gfall": "dist/gfall.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "pnpm build && node dist/gfall.js",
    "test": "pnpm build && node --test dist/gfall.test.js",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "listr2": "^10.2.1"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.13.1",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  }
}
